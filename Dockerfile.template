FROM node:20-alpine AS builder

RUN apk add --no-cache git python3 make g++

RUN git clone https://github.com/abhigyanpatwari/GitNexus.git /tmp/gitnexus && \
    cd /tmp/gitnexus && \
    git checkout {{VERSION}}

WORKDIR /tmp/gitnexus/gitnexus

RUN npm install -g @anthropic-ai/claude-code tree-sitter-cli typescript

WORKDIR /tmp/gitnexus/gitnexus-web

RUN npm install

RUN npm run build

FROM node:20-alpine

WORKDIR /app

RUN npm install -g serve gitnexus

COPY --from=builder /tmp/gitnexus/gitnexus-web/dist ./dist
COPY --from=builder /tmp/gitnexus/gitnexus-web/public ./public
COPY --from=builder /tmp/gitnexus/gitnexus-web/package.json ./package.json
COPY --from=builder /tmp/gitnexus/gitnexus-web/node_modules ./node_modules

RUN mkdir -p /data

EXPOSE 4747 5173

ENV HOST=0.0.0.0
ENV PORT=4747

CMD sh -c "gitnexus serve --port 4747 & serve -s dist -l 5173"
